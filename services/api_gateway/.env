COMMUNICATION_SERVICE_URL=http://communication-service:8006
NEWS_SERVICE_URL=http://news-service:8007

HTTP_CONNECT_TIMEOUT=5
HTTP_READ_TIMEOUT=30

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
