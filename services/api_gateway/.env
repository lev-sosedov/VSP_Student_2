APP_NAME=VSP Student API Gateway
APP_HOST=0.0.0.0
APP_PORT=8080
APP_ENV=development
DEBUG=true

AUTH_SERVICE_URL=http://auth-service:8000
USER_SERVICE_URL=http://user-service:8001
ACADEMIC_SERVICE_URL=http://academic-service:8002
SCHEDULE_SERVICE_URL=http://schedule-service:8003
CONTENT_SERVICE_URL=http://content-service:8004
