DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/notification_db

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

RABBITMQ_VIRTUAL_HOST=/

RABBITMQ_EXCHANGE=vsh_student
RABBITMQ_EXCHANGE_TYPE=topic

RABBITMQ_QUEUE=notification_service
RABBITMQ_ROUTING_KEY=#

RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_RECONNECT_INTERVAL=5
RABBITMQ_HEARTBEAT=60

RABBITMQ_DURABLE=true
RABBITMQ_MANDATORY=false
RABBITMQ_PERSISTENT_MESSAGES=true

USER_RPC_QUEUE=user_service.rpc
ACADEMIC_RPC_QUEUE=academic_service.rpc
SCHEDULE_RPC_QUEUE=schedule_service.rpc

SERVICE_HOST=0.0.0.0
SERVICE_PORT=8005

ENVIRONMENT=development